public void GunRotation(Vector3 directionToPlayer)
{
    float worldAngle =
             Mathf.Atan2(directionToPlayer.y, directionToPlayer.x)
             * Mathf.Rad2Deg
             - 90f;

    float tankAngle = transform.rotation.eulerAngles.z;
    if (tankAngle > 180f) tankAngle -= 360f;

    float localAngel = worldAngle - tankAngle;

    localAngel = Mathf.DeltaAngle(0f, localAngel);

    localAngel = Mathf.Clamp(localAngel, -angleLimitation, angleLimitation);

    Quaternion targetRotation = Quaternion.AngleAxis(localAngel, Vector3.forward);


    gunPoint.localRotation = Quaternion.RotateTowards(gunPoint.localRotation,
                             targetRotation,
                             gunRotationSpeed * Time.deltaTime
                          );
}
